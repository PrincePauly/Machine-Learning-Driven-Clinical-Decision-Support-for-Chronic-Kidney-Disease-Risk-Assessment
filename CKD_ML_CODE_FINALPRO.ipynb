    "# Train on the train split for a fair held-out evaluation\n",
    "lgb_final = lgb.LGBMClassifier(\n",
    "    class_weight=\"balanced\",\n",
    "    random_state=RANDOM_STATE,\n",
    "    verbose=-1\n",
    ")\n",
    "lgb_final.fit(X_train, y_train)\n",
    "lgb_pred = lgb_final.predict(X_test)\n",
    "\n",
    "cm = confusion_matrix(y_test, lgb_pred)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(6, 5))\n",
    "disp = ConfusionMatrixDisplay(\n",
    "    confusion_matrix=cm,\n",
    "    display_labels=label_encoder.classes_\n",
    ")\n",
    "disp.plot(ax=ax, colorbar=True, cmap=\"Blues\")\n",
    "ax.set_title(\"LightGBM (class-weighted) — Confusion Matrix\", weight=\"bold\")\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print()\n",
    "print(classification_report(y_test, lgb_pred, target_names=label_encoder.classes_))\n"
