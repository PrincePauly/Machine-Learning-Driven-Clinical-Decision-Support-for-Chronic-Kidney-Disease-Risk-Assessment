     "text": [
      "LightGBM — Macro F1 per fold: [0.4434 0.4441 0.4165 0.4366 0.4311]\n",
      "Mean Macro F1 : 0.4343 ± 0.0101\n"
     ]
    }
   ],
   "source": [
    "lgb_model = lgb.LGBMClassifier(\n",
    "    n_estimators=500,\n",
    "    learning_rate=0.05,\n",
    "    max_depth=6,\n",
    "    class_weight=\"balanced\",\n",
    "    random_state=RANDOM_STATE,\n",
    "    verbose=-1\n",
    ")\n",
    "\n",
    "scores_lgb = cross_val_score(\n",
    "    lgb_model,\n",
    "    X_selected, y,\n",
    "    cv=cv,\n",
    "    scoring=\"f1_macro\",\n",
    "    n_jobs=-1\n",
    ")\n",
    "\n",
    "print(f\"LightGBM — Macro F1 per fold: {scores_lgb.round(4)}\")\n",
    "print(f\"Mean Macro F1 : {scores_lgb.mean():.4f} ± {scores_lgb.std():.4f}\")\n"
   ]
