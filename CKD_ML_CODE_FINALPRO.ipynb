    "### 4.2 Feature and Target Separation\n",
    "\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/"
    },
    "id": "gkRRwuliLTFK",
    "outputId": "201aca1b-878f-4527-84c2-cecb759e3da5"
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Feature matrix shape: (10000, 32)\n",
      "Classes (encoded order): ['died', 'esrd', 'progressed', 'stable']\n"
     ]
    }
   ],
   "source": [
    "target = \"outcome\"\n",
    "\n",
    "X = df.drop(columns=[target])\n",
    "y = df[target]\n",
    "\n",
    "# One-hot encode categorical features\n",
    "X = pd.get_dummies(X, drop_first=True)\n",
    "\n",
    "# Integer-encode the target\n",
    "label_encoder = LabelEncoder()\n",
    "y = label_encoder.fit_transform(y)\n",
    "\n",
    "print(f\"Feature matrix shape: {X.shape}\")\n",
    "print(f\"Classes (encoded order): {list(label_encoder.classes_)}\")\n"
