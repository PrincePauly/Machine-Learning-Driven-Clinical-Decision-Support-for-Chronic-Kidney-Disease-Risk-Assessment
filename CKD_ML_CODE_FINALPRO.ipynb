   },
   "source": [
    "## 6. Addressing Class Imbalance using SMOTE (Synthetic Minority Over-sampling Technique)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/"
    },
    "id": "zcb9G1Z2LTFS",
    "outputId": "ce3a59ef-480e-40ea-cadc-f724099b9456"
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "SMOTE + XGBoost — Cross-validation Macro F1 per fold: [0.4199 0.4284 0.403  0.4145 0.4483]\n",
      "Mean Macro F1: 0.4228 ± 0.0152\n"
     ]
    }
   ],
   "source": [
    "# SMOTE + XGBoost pipeline (imbalance-aware)\n",
    "smote_pipeline = Pipeline([\n",
    "    (\"smote\", SMOTE(random_state=RANDOM_STATE)),\n",
    "    (\"model\", XGBClassifier(\n",
    "        objective=\"multi:softprob\",\n",
    "        eval_metric=\"mlogloss\",\n",
    "        random_state=RANDOM_STATE,\n",
    "        n_estimators=300,\n",
    "        max_depth=5,\n",
    "        learning_rate=0.05,\n",
    "        verbosity=0\n",
    "    ))\n",
    "])\n",
    "\n",
    "cv = StratifiedKFold(n_splits=N_SPLITS, shuffle=True, random_state=RANDOM_STATE)\n",
    "\n",
    "smote_cv_scores = cross_val_score(\n",
    "    smote_pipeline,\n",
    "    X, y,\n",
    "    cv=cv,\n",
    "    scoring=\"f1_macro\",\n",
    "    n_jobs=-1\n",
    ")\n",
    "\n",
    "print(f\"SMOTE + XGBoost — Cross-validation Macro F1 per fold: {smote_cv_scores.round(4)}\")\n",
    "print(f\"Mean Macro F1: {smote_cv_scores.mean():.4f} ± {smote_cv_scores.std():.4f}\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/",
     "height": 407
    },
    "id": "uJqWK1mqLTFT",
    "outputId": "7a0bc775-c71b-4888-c383-a58997ed7c67"
   },
   "outputs": [
    {
     "data": {
      "image/png": "\n",
