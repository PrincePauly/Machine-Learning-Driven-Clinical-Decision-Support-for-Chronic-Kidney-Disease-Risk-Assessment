     "text": [
      "Balanced Random Forest — Macro F1 per fold: [0.4261 0.4178 0.3967 0.4376 0.4385]\n",
      "Mean Macro F1 : 0.4233 ± 0.0154\n"
     ]
    }
   ],
   "source": [
    "brf = BalancedRandomForestClassifier(\n",
    "    n_estimators=400,\n",
    "    random_state=RANDOM_STATE\n",
    ")\n",
    "\n",
    "scores_brf = cross_val_score(\n",
    "    brf,\n",
    "    X_selected, y,\n",
    "    cv=cv,\n",
    "    scoring=\"f1_macro\",\n",
    "    n_jobs=-1\n",
    ")\n",
    "\n",
    "print(f\"Balanced Random Forest — Macro F1 per fold: {scores_brf.round(4)}\")\n",
    "print(f\"Mean Macro F1 : {scores_brf.mean():.4f} ± {scores_brf.std():.4f}\")\n"
   ]
