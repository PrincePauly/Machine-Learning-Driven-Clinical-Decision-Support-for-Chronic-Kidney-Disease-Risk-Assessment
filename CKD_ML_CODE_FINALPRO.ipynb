       "<Figure size 700x400 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "# Visualise fold-by-fold stability\n",
    "plt.figure(figsize=(7, 4))\n",
    "plt.plot(range(1, N_SPLITS + 1), smote_cv_scores, marker=\"o\", linewidth=2, color=\"#4C72B0\")\n",
    "plt.axhline(smote_cv_scores.mean(), linestyle=\"--\", color=\"grey\", label=f\"Mean = {smote_cv_scores.mean():.3f}\")\n",
    "plt.title(\"SMOTE + XGBoost — Cross-Validation F1 per Fold\", weight=\"bold\")\n",
    "plt.xlabel(\"Fold\")\n",
    "plt.ylabel(\"Macro F1 Score\")\n",
    "plt.legend()\n",
    "plt.tight_layout()\n",
    "plt.show()\n"
   ]
